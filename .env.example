# Required env vars for ASTA

# LLM Providers
GROQ_API_KEY=my_groq_key_here

# Speech Services
DEEPGRAM_API_KEY=my_deepgram_key_here

# Database
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/asta_db

# Telegram Integration
TELEGRAM_TOKEN=123456789:ABCDefGHIJKlmNOPQRstUVWXYZ
TELEGRAM_CHAT_ID=123456789

# Optional
DEBUG=false
GOOGLE_SA_KEY_PATH=path/to/key.json (if used)
