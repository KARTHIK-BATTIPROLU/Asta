# ── ASTA Production Environment ─────────────────────────────────────────────
# Copy to .env and fill in real values before deploying.
# NEVER commit the real .env file.

# ── Auth ─────────────────────────────────────────────────────────────────────
ASTA_API_BEARER_TOKEN=replace-with-a-long-random-secret

# ── LLM providers ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AI...

# ── MongoDB (app data + LangGraph checkpoints) ───────────────────────────────
# In Docker Compose the backend uses these service names automatically.
# For Railway / DO set these to the managed-MongoDB connection strings.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=asta_db

# ── Postgres (LangGraph checkpointer — preferred over Mongo for checkpoints) ─
# Docker Compose sets this automatically via the environment: block.
# On Railway / DO point at a managed Postgres or internal service URL.
POSTGRES_URL=postgresql://asta:asta@postgres:5432/asta_checkpoints

# ── Redis (L1 session cache) ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Pinecone (vector memory, L3) ─────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=asta-memory
PINECONE_EMBEDDING_DIM=384

# ── Neo4j (graph memory, L2) ─────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_ROUTINE_DB_ID=...
NOTION_RESEARCH_DB_ID=...
NOTION_CONTENT_DB_ID=...

# ── Deepgram (STT / TTS) ─────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── Serper (web search for research) ─────────────────────────────────────────
SERPER_API_KEY=...

# ── Wake word (optional — disable on server) ─────────────────────────────────
WAKE_WORD_ENABLED=false
WAKE_WORD_MODELS=hey_jarvis
WAKE_WORD_THRESHOLD=0.5
WAKE_WORD_COOLDOWN=2.0

# ── Firebase / FCM (bonus push notifications) ────────────────────────────────
# Place service-account.json in backend/secrets/ (gitignored).
# Set this path so the Admin SDK picks it up automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/app/backend/secrets/service-account.json
